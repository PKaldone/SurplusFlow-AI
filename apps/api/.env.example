# ============================================================
# SurplusFlow AI — API Environment Variables
# Copy to .env and update values for your environment
# ============================================================

NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://sfuser:sfpass_local_dev@localhost:5432/surplusflow
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://:sfredis_local_dev@localhost:6379

# --- JWT Authentication ---
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Magic Link (Claimant Auth) ---
MAGIC_LINK_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
MAGIC_LINK_EXPIRES_MINUTES=15

# --- MinIO / S3 Object Storage ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sfminio
S3_SECRET_KEY=sfminio_secret_local
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Encryption ---
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY!
SSN_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_SSN_KEY_HERE!!

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=claims@surplusflow.com

# --- SMS ---
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Application URLs ---
APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3002
