{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@surplusflow/shared": ["packages/shared/src"],
      "@surplusflow/rules": ["packages/rules/src"],
      "@surplusflow/contracts": ["packages/contracts/src"],
      "@surplusflow/audit": ["packages/audit/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
